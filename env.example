# PostgreSQL
POSTGRES_DB=consorcio
POSTGRES_USER=consorcio
POSTGRES_PASSWORD=consorcio_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=redis_secret

# n8n
N8N_USER=admin
N8N_PASSWORD=admin_secret
N8N_HOST=localhost
# Generate once with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=changeme_generate_a_random_key

# Claude API (for agents)
ANTHROPIC_API_KEY=sk-ant-...

# SMTP para envío de emails con expensas
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu@gmail.com
SMTP_PASS=tu_app_password
SMTP_FROM=tu@gmail.com

# WhatsApp — elegir un proveedor: "twilio" o "meta"
WA_PROVIDER=twilio

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Meta WhatsApp Business Cloud API
META_WA_TOKEN=EAAxxxxxxxxxx
META_WA_PHONE_NUMBER_ID=1234567890
META_WA_VERIFY_TOKEN=consorcio_verify

# Agentes
AGENT_API_KEY=una_clave_secreta_aleatoria
ADMIN_WHATSAPP_PHONE=+5491112345678

# Portal (inter-service)
COMMS_AGENT_URL=http://localhost:3002
